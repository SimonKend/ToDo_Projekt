<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="429.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.Controller_logged_in_user">
   <children>
      <Button fx:id="btnLogout" layoutX="535.0" layoutY="384.0" mnemonicParsing="false" onAction="#btnLogoutPressed" text="logout" />
      <Label fx:id="labelWelcomeMessage" layoutX="34.0" layoutY="81.0" text="Hello, Username, you are logged in!" />

      <ListView fx:id="listViewUsernames" layoutX="320.0" layoutY="75.0" prefHeight="300.0" prefWidth="240.0" visible="false" />
      <Label fx:id="lblAdminHeader" layoutX="320.0" layoutY="25.0" text="All Registered Users (Admin View):" visible="false" />
      <MenuBar fx:id="menuBar" layoutX="34.0" layoutY="30.0" prefHeight="25.0" prefWidth="532.0">
        <menus>
          <Menu fx:id="toDoMenu" mnemonicParsing="false" onAction="#toDoMenuPressed" text="ToDo's">
            <items>
              <MenuItem mnemonicParsing="false" text="ToDo's" />
            </items>
          </Menu>
          <Menu fx:id="userMenu" mnemonicParsing="false" onAction="#userMenuPressed" text="User">
            <items>
              <MenuItem mnemonicParsing="false" text="Settings" />
            </items>
          </Menu>
          <Menu fx:id="infosMenu" mnemonicParsing="false" onAction="#infosMenuPressed" text="Infos">
            <items>
              <MenuItem mnemonicParsing="false" text="Infos" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      <VBox fx:id="vBox" layoutX="34.0" layoutY="138.0" prefHeight="200.0" prefWidth="152.0" spacing="10.0" />
   </children>
</AnchorPane>
