<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="484.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.Controller_logged_in_ToDos">
   <children>
      <Label fx:id="labelWelcomeMessage" layoutX="34.0" layoutY="81.0" text="Hello, Username, you are logged in!" />

      <ListView fx:id="listViewUsernames" layoutX="350.0" layoutY="143.0" prefHeight="282.0" prefWidth="233.0" visible="false" />
      <Label fx:id="lblAdminHeader" layoutX="350.0" layoutY="114.0" prefHeight="17.0" prefWidth="182.0" text="All Registered Users:" visible="false" />
      <MenuBar fx:id="menuBar" layoutX="34.0" layoutY="30.0" prefHeight="25.0" prefWidth="532.0">
        <menus>
          <Menu fx:id="toDoMenu" mnemonicParsing="false" onShowing="#menuToDosShowed" text="Your ToDo's">
            <items>
              <MenuItem mnemonicParsing="false" text="Your ToDo's" />
            </items>
          </Menu>
          <Menu fx:id="userMenu" mnemonicParsing="false" onShowing="#menuUserInfosShowed" text="User Infos">
            <items>
              <MenuItem mnemonicParsing="false" text="User Infos" />
            </items>
          </Menu>
          <Menu fx:id="infosMenu" mnemonicParsing="false" onShowing="#menuGeneralInfosShowed" text="General Infos">
            <items>
              <MenuItem mnemonicParsing="false" text="General Infos" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      <VBox fx:id="vBox" layoutX="34.0" layoutY="135.0" prefHeight="264.0" prefWidth="261.0" spacing="10.0" />
      <Button fx:id="btnAddToDo" layoutX="311.0" layoutY="143.0" mnemonicParsing="false" onAction="#btnAddToDoPressed" prefHeight="25.0" prefWidth="30.0" text="➕" />
      <Label fx:id="labelWelcomeMessage1" layoutX="34.0" layoutY="106.0" text="Your ToDo's for today:" />
      <Button fx:id="btnLogout" layoutX="532.0" layoutY="438.0" mnemonicParsing="false" onAction="#btnLogoutPressed" text="logout" />
   </children>
</AnchorPane>
